<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <h2>Edit your Posts</h2>
    <p><b>Post id : @</b><%= post.id %></p>
    <p><b>Post username :</b> <%= post.username %></p>
    <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
      <textarea rows="5" cols="20" name="content"><%= post.content %></textarea>
      <br />
      <button>submit</button>
    </form>
  </body>
</html>
